FROM golang:1.23-alpine AS build

WORKDIR /src
RUN apk add --no-cache ca-certificates git

COPY go.mod go.sum ./
COPY sdk ./sdk
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/coin-server ./cmd/server

FROM alpine:3.20

RUN addgroup -S app && adduser -S -G app app && apk add --no-cache ca-certificates tzdata
WORKDIR /app

COPY --from=build /out/coin-server /app/coin-server

EXPOSE 8082
USER app
ENTRYPOINT ["/app/coin-server"]
