# ---- Database / Redis ----
POSTGRES_USER=coin
POSTGRES_PASSWORD=coin
POSTGRES_DB=coin
POSTGRES_PORT=5432

REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- API ----
API_PORT=8080
POSTGRES_MAX_CONNS=10

# Required: local KMS key for merchant secret encryption
LOCAL_KMS_KEY_V1=please_change_me_local_kms_key
# Required: admin JWT signing secret
ADMIN_JWT_SECRET=please_change_me_admin_jwt_secret
ADMIN_ENABLED=true

# ---- Admin Web ----
ADMIN_WEB_PORT=3000
NEXT_PUBLIC_ADMIN_API_BASE=/admin/api/v1

# ---- Optional auto-initialize (deploy.sh up will use these if provided) ----
ADMIN_SETUP_USERNAME=
ADMIN_SETUP_PASSWORD=
ADMIN_SETUP_MERCHANT_NAME=Default Merchant
